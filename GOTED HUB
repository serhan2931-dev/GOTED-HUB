-- --- MAX ULTRA PERFORMANCE BOOST ---
local function ApplyFPSBoost()
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    Lighting.GlobalShadows = false
    Lighting.EnvironmentSpecularScale = 0
    Workspace.Terrain.WaterWaveSize = 0
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") or v:IsA("Trail") then 
            v:Destroy() 
        end
        if v:IsA("BasePart") then 
            v.Material = Enum.Material.SmoothPlastic 
            v.CastShadow = false 
            v.Reflectance = 0
        end
    end
end

-- --- EVENT DRIVEN INTERACTION (NO LAG LOOPS) ---
local function CheckPrompt(obj)
    if not obj:IsA("ProximityPrompt") then return end
    local pName = string.lower(obj.Parent.Name .. obj.ObjectText .. obj.ActionText)
    
    if Flags.AutoBuy and string.find(pName, string.lower(TargetSeed)) then
        FirePrompt(obj)
    end
    
    if Flags.EventSniper then
        for _, term in pairs(SpecialTargets) do
            if string.find(pName, term) then
                FirePrompt(obj)
            end
        end
    end
end

Workspace.DescendantAdded:Connect(function(descendant)
    if Flags.AutoBuy or Flags.EventSniper then
        CheckPrompt(descendant)
    end
end)

task.spawn(function()
    while true do
        task.wait(0.5) -- Relaxed polling loop to save RAM
        if Flags.FPSBoost then ApplyFPSBoost() end
        if Flags.AutoBuy or Flags.EventSniper then
            pcall(function()
                for _, obj in pairs(Workspace:GetDescendants()) do
                    CheckPrompt(obj)
                end
            end)
        end
    end
end)

