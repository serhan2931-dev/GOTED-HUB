local function AddMenuButton(text, pos, flagKey, bgCol)
    local btn = Instance.new("TextButton", Scroll)
    btn.Size = UDim2.new(0.92, 0, 0, 38)
    btn.Position = pos
    btn.Text = text
    btn.BackgroundColor3 = bgCol
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSansBold
    Instance.new("UICorner", btn)
    
    btn.MouseButton1Down:Connect(function()
        if flagKey == "AutoFarm" and not Flags.AutoFarm and HRP then LockedHomeCFrame = HRP.CFrame end
        Flags[flagKey] = not Flags[flagKey]
        btn.TextSize = Flags[flagKey] and 16 or 14
    end)
end

local function CreateSelector(label, items, pos, bgCol, callback)
    local index = 1
    local btn = Instance.new("TextButton", Scroll)
    btn.Size = UDim2.new(0.92, 0, 0, 38)
    btn.Position = pos
    btn.Text = label .. ": " .. string.upper(items[1])
    btn.BackgroundColor3 = bgCol
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSansBold
    Instance.new("UICorner", btn)
    
    btn.MouseButton1Down:Connect(function()
        index = (index % #items) + 1
        btn.Text = label .. ": " .. string.upper(items[index])
        callback(items[index])
    end)
end

