-- --- 1. STRICT ANTI-SELF HARVEST PROTECTION ---
local function IsPlotFriendly(plot)
    local pName = string.lower(LocalPlayer.Name)
    local pDisplay = string.lower(LocalPlayer.DisplayName)
    local plotName = string.lower(plot.Name)
    
    if string.find(plotName, pName) or string.find(plotName, pDisplay) then return true end
    if plot:FindFirstChild("Owner") and plot.Owner.Value == LocalPlayer then return true end
    
    return false
end

