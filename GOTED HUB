local function IsNight()
    local ct = Lighting.ClockTime
    return ct >= 18 or ct <= 6
end

-- --- EXPERIMENTAL PHYS-FLING SYSTEM ---
local function ExecuteTargetFling()
    if not HRP or FlingTargetName == "" then return end
    local targetPlayer = Players:FindFirstChild(FlingTargetName)
    if not targetPlayer or not targetPlayer.Character then return end
    local targetHRP = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return end
    
    local oldCFrame = HRP.CFrame
    local bV = Instance.new("BodyVelocity")
    bV.MaxForce = Vector3.new(1, 1, 1) * math.huge
    bV.Velocity = Vector3.new(99999, 99999, 99999)
    bV.Parent = HRP
    
    local bAV = Instance.new("BodyAngularVelocity")
    bAV.MaxTorque = Vector3.new(1, 1, 1) * math.huge
    bAV.AngularVelocity = Vector3.new(99999, 99999, 99999)
    bAV.Parent = HRP
    
    -- Target Collision Sequence
    for i = 1, 35 do
        if not targetHRP or not HRP then break end
        HRP.CFrame = targetHRP.CFrame * CFrame.Angles(math.rad(math.random(-180, 180)), math.rad(math.random(-180, 180)), 0)
        task.wait(0.02)
    end
    
    -- Cleanup physical vectors & safely return
    bV:Destroy()
    bAV:Destroy()
    if LockedHomeCFrame then HRP.CFrame = LockedHomeCFrame else HRP.CFrame = oldCFrame end
end

