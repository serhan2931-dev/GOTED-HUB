-- --- PERFORMANCE ENGINE (LAG FIX) ---
local function ApplyFPSBoost()
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    Lighting.GlobalShadows = false
    Lighting.EnvironmentSpecularScale = 0
    Workspace.Terrain.WaterWaveSize = 0
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") then v:Destroy() end
        if v:IsA("BasePart") then v.Material = Enum.Material.SmoothPlastic v.CastShadow = false end
    end
end

-- --- FLING SYSTEM ---
local function ExecuteTargetFling()
    if not Flags.FlingEngine or not HRP or FlingTargetName == "" then return end
    local targetPlayer = Players:FindFirstChild(FlingTargetName)
    if not targetPlayer or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local targetHRP = targetPlayer.Character.HumanoidRootPart
    
    local oldCFrame = HRP.CFrame
    local bV = Instance.new("BodyVelocity", HRP)
    bV.MaxForce = Vector3.new(4000, 4000, 4000)
    bV.Velocity = Vector3.new(0, 50, 0)
    
    local bAV = Instance.new("BodyAngularVelocity", HRP)
    bAV.MaxTorque = Vector3.new(1, 1, 1) * 100000
    bAV.AngularVelocity = Vector3.new(0, 500, 0)
    
    for i = 1, 20 do
        if not Flags.FlingEngine then break end
        HRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0.5, 0)
        task.wait(0.05)
    end
    bV:Destroy() bAV:Destroy()
    HRP.CFrame = oldCFrame
end

-- --- LAG-OPTIMIZED AUTOMATION LOOP ---
task.spawn(function()
    while true do
        task.wait(0.25) -- Optimized interval to drop CPU usage drastically
        pcall(function()
            if Flags.FPSBoost then ApplyFPSBoost() end
            
            -- Only search interactive areas, not the entire Workspace
            for _, obj in pairs(Workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    local pName = string.lower(obj.Parent.Name .. obj.ObjectText .. obj.ActionText)
                    local act = string.lower(obj.ActionText)
                    
                    -- Auto Buy Packs
                    if Flags.AutoBuy and string.find(pName, string.lower(TargetSeed)) then 
                        FirePrompt(obj) 
                    end
                    
                    -- Event Sniper & Immediate Harvest/Sell
                    if Flags.EventSniper or Flags.AutoHarvestSell then
                        if string.find(act, "harvest") or string.find(act, "collect") or string.find(act, "claim") or string.find(act, "sell") then
                            FirePrompt(obj)
                        else
                            for _, term in pairs(SpecialTargets) do
                                if string.find(pName, term) then FirePrompt(obj) end
                            end
                        end
                    end
                end
            end
        end)
    end
end)

-- --- FIXED NIGHT STEAL SYSTEM ---
task.spawn(function()
    while true do
        task.wait(0.5)
        if Flags.NightSteal and HRP then
            pcall(function()
                for _, plot in pairs(Workspace:GetChildren()) do
                    local plotName = string.lower(plot.Name)
                    if string.find(plotName, "plot") or string.find(plotName, "garden") then
                        local isOwnPlot = false
                        if string.find(plotName, string.lower(LocalPlayer.Name)) or string.find(plotName, string.lower(LocalPlayer.DisplayName)) then
                            isOwnPlot = true
                        end
                        if plot:FindFirstChild("Owner") and plot.Owner.Value == LocalPlayer then
                            isOwnPlot = true
                        end
                        
                        if not isOwnPlot then
                            for _, p in pairs(plot:GetDescendants()) do
                                if p:IsA("ProximityPrompt") and (string.find(string.lower(p.ActionText), "harvest") or string.find(string.lower(p.ActionText), "steal")) then
                                    HRP.CFrame = p.Parent.CFrame
                                    task.wait(0.1)
                                    FirePrompt(p)
                                end
                            end
                        end
                    end
                end
            end)
        end
    end
end)

