-- --- 3. OPTIMIZED FLING ENGINE (NO LAG) ---
local function ExecuteFling(targetName)
    local target = Players:FindFirstChild(targetName)
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local HRP = LocalPlayer.Character.HumanoidRootPart
        -- Optimized velocity approach to prevent lag
        local vel = Instance.new("LinearVelocity", HRP)
        vel.MaxForce = 100000
        vel.VectorVelocity = (target.Character.HumanoidRootPart.Position - HRP.Position).Unit * 50
        task.wait(0.5)
        vel:Destroy()
    end
end

-- --- 4. MUTATION HARVEST FILTER ---
local function SmartHarvest(prompt)
    if Flags.AutoHarvest then
        local pName = string.lower(prompt.Parent.Name)
        if TargetMutation == "none" or string.find(pName, TargetMutation) then
            fireproximityprompt(prompt)
        end
    end
end

