task.spawn(function()
    while true do
        pcall(function()
            local rawTime = Lighting.ClockTime
            local displayHours = math.floor(rawTime) % 12
            if displayHours == 0 then displayHours = 12 end
            local minutes = math.floor((rawTime - math.floor(rawTime)) * 60)
            local ampm = rawTime >= 12 and "PM" or "AM"
            
            -- Dynamic Countdown Calculations based on Sky Position
            local untilNight = IsNight() and 0 or math.floor((18 - rawTime) * 50)
            local untilDay = not IsNight() and 0 or (rawTime > 18 and math.floor((30 - rawTime) * 50) or math.floor((6 - rawTime) * 50))
            local cycleTimer = IsNight() and "☀️ Day in: " .. untilDay .. "s" or "🌙 Night in: " .. untilNight .. "s"
            
            TopTimerBar.Text = string.format(" CLOCK: %02d:%02d %s | %s\n STATUS: %s", displayHours, minutes, ampm, cycleTimer, LockedHomeCFrame and "🔒 PLOT SECURED" or "⚠️ HARVEST HOME TO LOCK PLOT")
        end)
        task.wait(0.5)
    end
end)

-- --- SELECTION TOGGLE BUTTON BUILDER ---
local function AddMenuButton(text, pos, flagKey, callback)
    local btn = Instance.new("TextButton", Scroll)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Position = pos
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSansBold
    Instance.new("UICorner", btn)
    
    btn.MouseButton1Down:Connect(function()
        if flagKey == "AutoFarm" and not Flags.AutoFarm and HRP then LockedHomeCFrame = HRP.CFrame end
        Flags[flagKey] = not Flags[flagKey]
        btn.BackgroundColor3 = Flags[flagKey] and Color3.fromRGB(46, 139, 87) or Color3.fromRGB(45, 45, 45)
        if callback and Flags[flagKey] then callback() end
    end)
end

-- --- OPTIONS DROP-DOWNS CREATOR ---
local function CreateSelector(label, items, initial, pos, callback)
    local index = 1
    local btn = Instance.new("TextButton", Scroll)
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Position = pos
    btn.Text = label .. ": " .. string.upper(initial)
    btn.BackgroundColor3 = Color3.fromRGB(35, 65, 95)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSansBold
    Instance.new("UICorner", btn)
    
    btn.MouseButton1Down:Connect(function()
        index = (index % #items) + 1
        btn.Text = label .. ": " .. string.upper(items[index])
        callback(items[index])
    end)
end

