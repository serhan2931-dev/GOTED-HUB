local Flags = {
    AutoFarm = false, AutoWater = false, AutoBuy = false, AutoReplant = false,
    EventCollector = false, SpeedToggle = false, NoClip = false, FPSBoost = false, 
    NightSteal = false, AutoBuyPets = false
}

local CustomSpeed = 45
local TargetSeed = "bamboo"  -- Default smart-farm target
local TargetEgg = "egg"      -- Default gacha target

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local Terrain = Workspace:FindFirstChildWhichIsA("Terrain")

local Character, HRP, LockedHomeCFrame
local function UpdateCache(char)
    Character = char
    HRP = char:WaitForChild("HumanoidRootPart", 5)
end
LocalPlayer.CharacterAdded:Connect(UpdateCache)
if LocalPlayer.Character then UpdateCache(LocalPlayer.Character) end

local function IsNight()
    local ct = Lighting.ClockTime
    return ct >= 18 or ct <= 6
end

-- --- FORCED HIGH PERFORMANCE MODE ---
local function ApplyFPSBoost()
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    if Terrain then Terrain.WaterWaveSize = 0 Terrain.WaterDetail = Enum.WaterDetailSetting.Low end
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("BasePart") and not v:IsA("MeshPart") then v.Material = Enum.Material.SmoothPlastic v.Reflectance = 0
        elseif v:IsA("Texture") or v:IsA("Decal") then v:Destroy() end
    end
end

-- --- AUTOMATION LOGIC ENGINES ---
task.spawn(function()
    while true do
        -- 1. Targeted Pet/Egg Buyer
        if Flags.AutoBuyPets then
            pcall(function()
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    if obj:IsA("ProximityPrompt") then
                        local nameLower = string.lower(obj.Parent.Name)
                        if string.find(nameLower, TargetEgg) or string.find(string.lower(obj.ObjectText or ""), TargetEgg) then
                            fireproximityprompt(obj)
                        end
                    end
                end
            end)
        end

        -- 2. Targeted Seed Pack Buyer
        if Flags.AutoBuy then
            pcall(function()
                for _, obj in ipairs(Workspace:GetDescendants()) do
                    if obj:IsA("ProximityPrompt") then
                        local nameLower = string.lower(obj.Parent.Name)
                        if string.find(nameLower, TargetSeed) and (string.find(nameLower, "seed") or string.find(nameLower, "shop")) then
                            fireproximityprompt(obj)
                        end
                    end
                end
            end)
        end

        -- 3. Home Plot Harvest & Utilities
        if HRP and LockedHomeCFrame then
            pcall(function()
                for _, obj in ipairs(Workspace:GetChildren()) do
                    if string.find(string.lower(obj.Name), "plot") or string.find(string.lower(obj.Name), "garden") then
                        for _, prompt in ipairs(obj:GetDescendants()) do
                            if prompt:IsA("ProximityPrompt") then
                                local distance = (prompt.Parent.Position - LockedHomeCFrame.Position).Magnitude
                                if distance <= 60 then
                                    if Flags.AutoFarm and string.find(string.lower(prompt.Parent.Name), "harvest") then
                                        fireproximityprompt(prompt)
                                    elseif Flags.AutoWater and string.find(string.lower(prompt.Name), "water") then
                                        fireproximityprompt(prompt)
                                    elseif Flags.AutoReplant and string.find(string.lower(prompt.Name), "plant") then
                                        fireproximityprompt(prompt)
                                    end
                                end
                            end
                        end
                    end
                end
            end)
        end

        -- 4. Protected Night Stealer
        if Flags.NightSteal and IsNight() and HRP then
            pcall(function()
                for _, obj in ipairs(Workspace:GetChildren()) do
                    if string.find(string.lower(obj.Name), "plot") or string.find(string.lower(obj.Name), "garden") then
                        for _, prompt in ipairs(obj:GetDescendants()) do
                            if prompt:IsA("ProximityPrompt") and string.find(string.lower(prompt.Parent.Name), "harvest") then
                                local distance = LockedHomeCFrame and (prompt.Parent.Position - LockedHomeCFrame.Position).Magnitude or 999
                                if not LockedHomeCFrame or distance > 60 then
                                    HRP.CFrame = prompt.Parent.CFrame * CFrame.new(0, 2, 0)
                                    task.wait(0.12)
                                    fireproximityprompt(prompt)
                                    task.wait(0.12)
                                end
                            end
                        end
                    end
                end
            end)
        end
        task.wait(0.4)
    end
end)

