local Character, HRP
local function UpdateCache(char)
    Character = char
    HRP = char:WaitForChild("HumanoidRootPart", 5)
end
LocalPlayer.CharacterAdded:Connect(UpdateCache)
if LocalPlayer.Character then UpdateCache(LocalPlayer.Character) end

-- --- INSTANT INTERACTION ENGINE ---
local function FirePrompt(prompt)
    if prompt:IsA("ProximityPrompt") then
        fireproximityprompt(prompt)
    end
end

-- --- MOVEMENT ENGINE ---
RunService.Heartbeat:Connect(function()
    if Character and HRP and Character:FindFirstChild("Humanoid") then
        if Flags.SpeedToggle then Character.Humanoid.WalkSpeed = 70 end
        if Flags.NoClip then
            for _, p in pairs(Character:GetDescendants()) do 
                if p:IsA("BasePart") then p.CanCollide = false end 
            end
        end
    end
end)

UserInputService.JumpRequest:Connect(function()
    if Flags.InfJump and Character and Character:FindFirstChild("Humanoid") then 
        Character.Humanoid:ChangeState("Jumping") 
    end
end)

-- --- PERFORMANCE ENGINE (FPS BOOST) ---
local function ApplyFPSBoost()
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    Lighting.GlobalShadows = false
    Lighting.EnvironmentSpecularScale = 0
    Workspace.Terrain.WaterWaveSize = 0
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") then v:Destroy() end
        if v:IsA("BasePart") then v.Material = Enum.Material.SmoothPlastic v.CastShadow = false end
    end
end

-- --- FIXED TARGET FLING SYSTEM ---
local function ExecuteTargetFling()
    if not Flags.FlingEngine or not HRP or FlingTargetName == "" then return end
    local targetPlayer = Players:FindFirstChild(FlingTargetName)
    if not targetPlayer or not targetPlayer.Character then return end
    local targetHRP = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return end
    
    local oldCFrame = HRP.CFrame
    local bV = Instance.new("BodyVelocity")
    bV.MaxForce = Vector3.new(1, 1, 1) * math.huge
    bV.Velocity = Vector3.new(99999, 99999, 99999)
    bV.Parent = HRP
    
    local bAV = Instance.new("BodyAngularVelocity")
    bAV.MaxTorque = Vector3.new(1, 1, 1) * math.huge
    bAV.AngularVelocity = Vector3.new(99999, 99999, 99999)
    bAV.Parent = HRP
    
    for i = 1, 35 do
        if not Flags.FlingEngine or not targetHRP or not HRP then break end
        HRP.CFrame = targetHRP.CFrame * CFrame.Angles(math.rad(math.random(-180, 180)), math.rad(math.random(-180, 180)), 0)
        task.wait(0.02)
    end
    
    bV:Destroy()
    bAV:Destroy()
    HRP.CFrame = oldCFrame
end

-- --- AUTOMATION ENGINES LOOP ---
task.spawn(function()
    while true do
        task.wait(0.1)
        pcall(function()
            if Flags.FPSBoost then ApplyFPSBoost() end
            
            for _, obj in pairs(Workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    local pName = string.lower(obj.Parent.Name .. obj.ObjectText .. obj.ActionText)
                    local actionText = string.lower(obj.ActionText)
                    
                    -- Auto Buy Filter
                    if Flags.AutoBuy and string.find(pName, string.lower(TargetSeed)) then
                        FirePrompt(obj)
                    end
                    
                    -- FIXED MOON & EVENT SNIPER FILTER
                    -- Automatically captures prompts matching specific action commands during world/moon events
                    if Flags.EventSniper then
                        if string.find(actionText, "harvest") or string.find(actionText, "collect") or string.find(actionText, "claim") or string.find(actionText, "grab") then
                            FirePrompt(obj)
                        else
                            for _, term in pairs(SpecialTargets) do
                                if string.find(pName, term) then
                                    FirePrompt(obj)
                                end
                            end
                        end
                    end
                end
            end
        end)
    end
end)

-- --- FIXED ANTI-SELF NIGHT STEAL SYSTEM ---
task.spawn(function()
    while true do
        task.wait(0.4)
        if Flags.NightSteal and HRP then
            pcall(function()
                for _, plot in pairs(Workspace:GetChildren()) do
                    local plotName = string.lower(plot.Name)
                    if string.find(plotName, "plot") or string.find(plotName, "garden") then
                        
                        -- CRITICAL: Prevent stealing from your own plot layout
                        local isOwnPlot = false
                        if string.find(plotName, string.lower(LocalPlayer.Name)) or string.find(plotName, string.lower(LocalPlayer.DisplayName)) then
                            isOwnPlot = true
                        end
                        if plot:FindFirstChild("Owner") and plot.Owner.Value == LocalPlayer then
                            isOwnPlot = true
                        end
                        
                        if not isOwnPlot then
                            for _, p in pairs(plot:GetDescendants()) do
                                if p:IsA("ProximityPrompt") and string.find(string.lower(p.ActionText), "harvest") then
                                    HRP.CFrame = p.Parent.CFrame
                                    task.wait(0.15)
                                    FirePrompt(p)
                                end
                            end
                        end
                    end
                end
            end)
        end
    end
end)

