-- Fling Execution Logic
local function ExecuteTargetFling()
    local HRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not Flags.FlingEngine or not HRP or FlingTargetName == "" then return end
    local targetPlayer = Players:FindFirstChild(FlingTargetName)
    if not targetPlayer or not targetPlayer.Character then return end
    local targetHRP = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not targetHRP then return end
    
    local oldCFrame = HRP.CFrame
    local bV = Instance.new("BodyVelocity")
    bV.MaxForce = Vector3.new(1, 1, 1) * math.huge
    bV.Velocity = Vector3.new(40000, 40000, 40000)
    bV.Parent = HRP
    
    local bAV = Instance.new("BodyAngularVelocity")
    bAV.MaxTorque = Vector3.new(1, 1, 1) * math.huge
    bAV.AngularVelocity = Vector3.new(40000, 40000, 40000)
    bAV.Parent = HRP
    
    for i = 1, 30 do
        if not Flags.FlingEngine or not targetHRP or not HRP then break end
        HRP.CFrame = targetHRP.CFrame * CFrame.new(math.random(-1, 1), 0, math.random(-1, 1))
        task.wait(0.02)
    end
    
    bV:Destroy()
    bAV:Destroy()
    HRP.CFrame = oldCFrame
    Flags.FlingEngine = false
end

