task.spawn(function()
    while true do
        pcall(function()
            local weather = (Lighting:GetAttribute("Weather") or Workspace:GetAttribute("Weather") or "Normal"):lower()
            local clock = Lighting.ClockTime
            local isNight = (clock >= 18 or clock <= 6)
            
            -- Calculate precise prediction steps
            local remainingTime = 0
            local timerString = ""
            
            if not isNight then
                -- Day lasts until clock hits 18
                remainingTime = math.max(0, 18 - clock)
                local minutes = math.floor(remainingTime * 60)
                timerString = string.format("\n🌙 NEXT MOON IN: %dm", minutes)
                
                HUD.Text = "☀️ DAYTIME (GROWING PHASE)" .. timerString
                HUD.TextColor3 = Color3.fromRGB(255, 223, 0)
                HUDStroke.Color = Color3.fromRGB(255, 223, 0)
            else
                -- Night lasts until clock hits 6 (handles crossing midnight at 24)
                if clock >= 18 then
                    remainingTime = (24 - clock) + 6
                else
                    remainingTime = 6 - clock
                end
                local minutes = math.floor(remainingTime * 60)
                timerString = string.format("\n☀️ DAYBREAK IN: %dm", minutes)
                
                if weather:find("blood") then 
                    HUD.Text = "🔴 BLOOD MOON ACTIVE [MUTATION BOOST]" .. timerString
                    HUD.TextColor3 = Color3.fromRGB(255, 0, 0)
                    HUDStroke.Color = Color3.fromRGB(255, 0, 0)
                elseif weather:find("gold") or weather:find("midas") then 
                    HUD.Text = "🟡 GOLDEN MOON ACTIVE [SNIPING ALL GOLD]" .. timerString
                    HUD.TextColor3 = Color3.fromRGB(255, 215, 0)
                    HUDStroke.Color = Color3.fromRGB(255, 215, 0)
                elseif weather:find("rainbow") then 
                    HUD.Text = "🌈 RAINBOW MOON ACTIVE [SNIPING ALL RAINBOW]" .. timerString
                    HUD.TextColor3 = Color3.fromRGB(255, 105, 180)
                    HUDStroke.Color = Color3.fromRGB(255, 105, 180)
                elseif weather:find("mega") then 
                    HUD.Text = "🔵 MEGA MOON ACTIVE [SNIPING ALL MEGA]" .. timerString
                    HUD.TextColor3 = Color3.fromRGB(0, 255, 255)
                    HUDStroke.Color = Color3.fromRGB(0, 255, 255)
                else 
                    HUD.Text = "🌙 NORMAL NIGHT ACTIVE [STEAL ENGINE READY]" .. timerString
                    HUD.TextColor3 = Color3.fromRGB(200, 200, 200)
                    HUDStroke.Color = Color3.fromRGB(45, 45, 55)
                end
            end
        end)
        task.wait(1) -- Throttle to once per second to reduce client resource drain completely
    end
end)

