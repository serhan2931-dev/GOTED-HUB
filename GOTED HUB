local function AddMenuButton(text, pos, flagKey, defaultCol, callback)
    local btn = Instance.new("TextButton", Scroll)
    btn.Size = UDim2.new(0.92, 0, 0, 36)
    btn.Position = pos
    btn.Text = text .. " [OFF]"
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSansBold
    Instance.new("UICorner", btn)
    
    btn.MouseButton1Down:Connect(function()
        Flags[flagKey] = not Flags[flagKey]
        btn.Text = text .. (Flags[flagKey] and " [ON]" or " [OFF]")
        btn.BackgroundColor3 = Flags[flagKey] and defaultCol or Color3.fromRGB(40, 40, 50)
        if callback then callback(Flags[flagKey]) end
    end)
end

local function CreateSelector(label, items, pos, bgCol, callback)
    local index = 1
    local btn = Instance.new("TextButton", Scroll)
    btn.Size = UDim2.new(0.92, 0, 0, 36)
    btn.Position = pos
    btn.Text = label .. ": " .. string.upper(items[1])
    btn.BackgroundColor3 = bgCol
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.SourceSansBold
    Instance.new("UICorner", btn)
    
    btn.MouseButton1Down:Connect(function()
        index = (index % #items) + 1
        btn.Text = label .. ": " .. string.upper(items[index])
        callback(items[index])
    end)
end

