local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- UI Elements
local screenGui = script.Parent
local menuToggleButton = screenGui:WaitForChild("MenuToggleButton")
local mainPanel = screenGui:WaitForChild("MainPanel")
local sprintToggleBtn = mainPanel:WaitForChild("SprintToggleBtn")

-- Color Definitions
local COLOR_BG = Color3.fromRGB(30, 30, 35)
local COLOR_BLUE = Color3.fromRGB(0, 150, 255)
local COLOR_GREEN = Color3.fromRGB(46, 204, 113)
local COLOR_RED = Color3.fromRGB(231, 76, 60)
local COLOR_TEXT = Color3.fromRGB(255, 255, 255)

-- Setup Initial Visual Style
mainPanel.BackgroundColor3 = COLOR_BG
mainPanel.BorderSizePixel = 0
mainPanel.Visible = false

menuToggleButton.BackgroundColor3 = COLOR_BLUE
menuToggleButton.TextColor3 = COLOR_TEXT
menuToggleButton.Text = "🎨 Open Menu"

sprintToggleBtn.BackgroundColor3 = COLOR_RED
sprintToggleBtn.TextColor3 = COLOR_TEXT
sprintToggleBtn.Text = "Speed: OFF"

-- State Tracking
local menuVisible = false
local sprintActive = false

-- Animation Helper Function
local function fadeToColor(element, targetColor)
	local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local tween = TweenService:Create(element, tweenInfo, {BackgroundColor3 = targetColor})
	tween:Play()
end

-- 1. Menu Toggle (Open/Hide) with Animation
menuToggleButton.MouseButton1Click:Connect(function()
	menuVisible = not menuVisible
	mainPanel.Visible = menuVisible
	
	if menuVisible then
		menuToggleButton.Text = "❌ Close Menu"
		fadeToColor(menuToggleButton, Color3.fromRGB(50, 50, 55)) -- Darkens when open
	else
		menuToggleButton.Text = "🎨 Open Menu"
		fadeToColor(menuToggleButton, COLOR_BLUE)
	end
end)

-- 2. Feature Toggle (On/Off) with Dynamic Colors
sprintToggleBtn.MouseButton1Click:Connect(function()
	local character = player.Character or player.CharacterAdded:Wait()
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	
	sprintActive = not sprintActive
	
	if sprintActive then
		humanoid.WalkSpeed = 32
		sprintToggleBtn.Text = "🟢 Speed: ON"
		fadeToColor(sprintToggleBtn, COLOR_GREEN)
	else
		humanoid.WalkSpeed = 16
		sprintToggleBtn.Text = "🔴 Speed: OFF"
		fadeToColor(sprintToggleBtn, COLOR_RED) -- Fixed the broken line here
	end
end)

-- Make sure speed persists if the player dies/respawns while speed is active
player.CharacterAdded:Connect(function(newCharacter)
	if sprintActive then
		local humanoid = newCharacter:WaitForChild("Humanoid")
		humanoid.WalkSpeed = 32
	end
end)
