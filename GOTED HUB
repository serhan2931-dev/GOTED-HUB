local function UpdatePlayerList()
    PlayerScroll:ClearAllChildren()
    local Layout = Instance.new("UIListLayout", PlayerScroll)
    Layout.SortOrder, Layout.Padding = Enum.SortOrder.Name, UDim.new(0, 5)
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local btn = Instance.new("TextButton", PlayerScroll)
            btn.Size = UDim2.new(1, -10, 0, 25) btn.Text = p.Name
            btn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
            btn.TextColor3, btn.Font = Color3.new(1, 1, 1), Enum.Font.SourceSans
            
            btn.MouseButton1Down:Connect(function()
                for _, b in pairs(PlayerScroll:GetChildren()) do 
                    if b:IsA("TextButton") then b.BackgroundColor3 = Color3.fromRGB(40, 40, 50) end 
                end
                btn.BackgroundColor3 = Color3.fromRGB(0, 255, 0) -- GREEN LIGHT
                FlingTargetName = p.Name
                SelectedLabel.Text = "Target: " .. p.Name
            end)
        end
    end
end
