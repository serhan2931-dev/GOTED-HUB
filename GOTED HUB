local function UpdatePlayerList()
    PlayerScroll:ClearAllChildren()
    Instance.new("UIListLayout", PlayerScroll).SortOrder = Enum.SortOrder.Name
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local pBtn = Instance.new("TextButton", PlayerScroll)
            pBtn.Size = UDim2.new(1, 0, 0, 25)
            pBtn.Text = p.Name
            pBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
            pBtn.TextColor3 = Color3.new(1, 1, 1)
            pBtn.Font = Enum.Font.SourceSans
            pBtn.TextSize = 12
            
            pBtn.MouseButton1Down:Connect(function()
                FlingTargetName = p.Name
                SelectedLabel.Text = "Target: " .. p.Name
            end)
        end
    end
end
Players.PlayerAdded:Connect(UpdatePlayerList)
