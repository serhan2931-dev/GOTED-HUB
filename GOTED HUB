-- --- ANTI-SELF PROTECTION ---
local function IsPlotFriendly(plot)
    if not plot then return false end
    local nameLower = string.lower(plot.Name or "")
    if string.find(nameLower, string.lower(LocalPlayer.Name or "")) or string.find(nameLower, string.lower(LocalPlayer.DisplayName or "")) then 
        return true 
    end
    local owner = plot:FindFirstChild("Owner")
    if owner and owner.Value == LocalPlayer then return true end
    return false
end

