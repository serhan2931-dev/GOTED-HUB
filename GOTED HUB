    NightSteal = false, AutoHarvest = false, FlingEngine = false,
    AutoBuy = false, AutoSell = false
}

local TargetMutation = "none" -- Options: none, gold, rainbow, mega

-- --- 1. MOON PREDICTION CALCULATOR ---
local function GetMoonPrediction()
    local c = Lighting.ClockTime
    if c >= 18 or c <= 6 then
        return "NIGHT - ACTIVE"
    else
        local mins = math.floor((18 - c) * 60)
        return "DAY - " .. mins .. "M TO NEXT MOON"
    end
end

